@model ContactInfo
@{
    ViewData["Title"] = "Contact Details";
}

<h2>Contact Details</h2>
<hr />

<dl class="row">
    <dt class="col-sm-2">Contact ID</dt>
    <dd class="col-sm-10">@Model.ContactId</dd>

    <dt class="col-sm-2">First Name</dt>
    <dd class="col-sm-10">@Model.FirstName</dd>

    <dt class="col-sm-2">Last Name</dt>
    <dd class="col-sm-10">@Model.LastName</dd>

    <dt class="col-sm-2">Email</dt>
    <dd class="col-sm-10">@Model.EmailId</dd>

    <dt class="col-sm-2">Mobile</dt>
    <dd class="col-sm-10">@Model.MobileNo</dd>

    <dt class="col-sm-2">Designation</dt>
    <dd class="col-sm-10">@Model.Designation</dd>

    <dt class="col-sm-2">Company</dt>
    <dd class="col-sm-10">@Model.CompanyName</dd>

    <dt class="col-sm-2">Department</dt>
    <dd class="col-sm-10">@Model.DepartmentName</dd>
</dl>

<div class="mt-3">
    <a href="/Contact/EditContact/@Model.ContactId" class="btn btn-secondary">Edit</a>
    <a href="/Contact/ShowContacts" class="btn btn-secondary">Back</a>
    <a href="/Contact/DeleteContact/@Model.ContactId" class="btn btn-danger">Delete</a>
</div>

