@model WebApplication5.Models.ContactInfo
@{
    ViewData["Title"] = "Delete Contact";
}

<h2>Delete Contact</h2>

<h4>Are you sure you want to delete this contact?</h4>
<p><strong>@Model.FirstName @Model.LastName</strong> (<strong>@Model.EmailId</strong>)</p>

<form asp-action="DeleteContact" method="post">
    <input type="hidden" asp-for="ContactId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a href="/Contact/ShowContacts" class="btn btn-secondary">Cancel</a>
</form>
