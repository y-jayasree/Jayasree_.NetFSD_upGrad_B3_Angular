@model List<WebApplication5.Models.ContactInfo>
@{
    ViewData["Title"] = "All Contacts";
}

<h2>All Contacts</h2>
<a href="/Contact/AddContact">Add Contact</a>

<table class="table table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Mobile</th>
            <th>Designation</th>
            <th>Company</th>
            <th>Department</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.FirstName @c.LastName</td>
                <td>@c.EmailId</td>
                <td>@c.MobileNo</td>
                <td>@c.Designation</td>
                <td>@c.CompanyName</td>
                <td>@c.DepartmentName</td>
                <td>
                    <a href="/Contact/EditContact/@c.ContactId">Edit</a> |
                    <a href="/Contact/ViewContact/@c.ContactId">View</a> |
                    <a href="/Contact/DeleteContact/@c.ContactId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

